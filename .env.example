# Supabase 雲端資料庫與驗證設定範本
# 請複製此檔案並命名為 .env，然後填入您的實際連線資訊。

# Supabase 專案 URL (例如: https://your-project.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Supabase 專案的 Anon Key (公開金鑰)
SUPABASE_ANON_KEY=your-anon-key-here

# ── NLC 紟道生態系整合設定 ──────────────────────────────────────
# 向 NLC IT 申請註冊後取得。詳見: https://nlc-b1ffeeba.mintlify.site/sso/quickstart

# Logto OIDC 發行者 URL (固定不變)
NLC_LOGTO_ISSUER=https://sso.newlife.org.tw/oidc

# 應用的 Logto client ID (向 NLC IT 申請註冊後取得)
NLC_CLIENT_ID=your-logto-client-id-here

# Member Hub 基礎 URL
NLC_MEMBER_HUB_URL=https://member.newlife.org.tw

# OIDC scopes allowed by NLC SSO. Keep minimal unless NLC enables more scopes.
NLC_SCOPES=openid
